#!/bin/bash -l
#PBS -l select=1:system=polaris:ncpus=64:ngpus=4
#PBS -l walltime=00:10:00
#PBS -q debug-scaling
#PBS -A IMPROVE_Aim1
#PBS -l filesystems=eagle:home
#PBS -j oe
#PBS -N v15_smoke

# Quick smoke test: verify environment setup matches v15_experiment.pbs
# Should complete in <1 min — just checks python, accelerate, imports, GPU

set -euo pipefail

REPO_DIR=/lus/eagle/projects/IMPROVE_Aim1/caom/RePO
ADA_DIR=/lus/eagle/projects/IMPROVE_Aim1/caom/agent_drug_discovery/adaptive_repo
ENV_DIR=/lus/eagle/projects/IMPROVE_Aim1/caom/repo_env
LOG_DIR=${ADA_DIR}/logs

mkdir -p "${LOG_DIR}"
exec > "${LOG_DIR}/v15ms_smoketest_${PBS_JOBID}.log" 2>&1

echo "=============================================="
echo "SMOKE TEST — $(date)"
echo "Node: $(hostname)"
echo "=============================================="

export PATH="${ENV_DIR}/bin:${PATH}"
export PYTHONPATH="${REPO_DIR}/src:${ADA_DIR}:${PYTHONPATH:-}"

export CUDA_HOME=/opt/nvidia/hpc_sdk/Linux_x86_64/25.5/cuda
CUDA_MATH_LIBS=/opt/nvidia/hpc_sdk/Linux_x86_64/25.5/math_libs/12.9/targets/x86_64-linux/lib
export LD_LIBRARY_PATH=${CUDA_HOME}/lib64:${CUDA_MATH_LIBS}:${LD_LIBRARY_PATH:-}
export LIBRARY_PATH=${CUDA_MATH_LIBS}:${LIBRARY_PATH:-}
export DS_SKIP_CUDA_CHECK=1

echo ""
echo "1. which python: $(which python)"
echo "2. python version: $(python --version)"
echo "3. which accelerate: $(which accelerate)"
echo ""

echo "4. Python imports..."
python -c "
import torch
print(f'   torch={torch.__version__}, CUDA={torch.cuda.is_available()}, GPUs={torch.cuda.device_count()}')
for i in range(torch.cuda.device_count()):
    print(f'   GPU {i}: {torch.cuda.get_device_name(i)} ({torch.cuda.get_device_properties(i).total_mem / 1e9:.1f} GB)')

import transformers, trl, deepspeed, vllm
print(f'   transformers={transformers.__version__}')
print(f'   trl={trl.__version__}')
print(f'   deepspeed={deepspeed.__version__}')
print(f'   vllm={vllm.__version__}')

from x_r1.repo import main as repo_main
print('   x_r1.repo imported OK')

from adaptive_repo.ada_repo import main as ada_main
print('   adaptive_repo.ada_repo imported OK')

from adaptive_repo.dynamic_beta import DynamicBetaController
print('   DynamicBetaController imported OK')
print()
print('ALL IMPORTS PASSED')
"

echo ""
echo "5. Test accelerate config..."
accelerate env

echo ""
echo "=============================================="
echo "SMOKE TEST PASSED — $(date)"
echo "=============================================="
