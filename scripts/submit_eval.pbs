#!/bin/bash
#PBS -l select=1:system=polaris:ncpus=64:ngpus=1
#PBS -l walltime=06:00:00
#PBS -l filesystems=home:eagle
#PBS -q preemptable
#PBS -A IMPROVE_Aim1
#PBS -N eval_repo
#PBS -j oe
#PBS -o /lus/eagle/projects/IMPROVE_Aim1/caom/

# ==============================================
# Evaluation: generate predictions + evaluate
# Pass MODEL_PATH via -v
# Uses 1 GPU for vLLM inference
# ==============================================

set -euo pipefail

LOG_DIR=/lus/eagle/projects/IMPROVE_Aim1/caom/RePO/logs
mkdir -p ${LOG_DIR}
exec > ${LOG_DIR}/eval_${PBS_JOBID}.log 2>&1

PROJECT_DIR=/lus/eagle/projects/IMPROVE_Aim1/caom/RePO
ENV_DIR=/lus/eagle/projects/IMPROVE_Aim1/caom/repo_env

export PATH="${ENV_DIR}/bin:${PATH}"
export PYTHONPATH="${PROJECT_DIR}/src/x_r1:${PYTHONPATH:-}"

export CUDA_HOME=/opt/nvidia/hpc_sdk/Linux_x86_64/25.5/cuda
CUDA_MATH_LIBS=/opt/nvidia/hpc_sdk/Linux_x86_64/25.5/math_libs/12.9/targets/x86_64-linux/lib
export LIBRARY_PATH=${CUDA_HOME}/lib64:${CUDA_MATH_LIBS}:${LIBRARY_PATH:-}
export LD_LIBRARY_PATH=${CUDA_HOME}/lib64:${CUDA_MATH_LIBS}:${LD_LIBRARY_PATH:-}
export DS_SKIP_CUDA_CHECK=1

export HF_HOME=/lus/eagle/projects/IMPROVE_Aim1/caom/.cache/huggingface
export TRANSFORMERS_CACHE=/lus/eagle/projects/IMPROVE_Aim1/caom/.cache/huggingface
export HF_DATASETS_CACHE=/lus/eagle/projects/IMPROVE_Aim1/caom/.cache/huggingface/datasets

export HTTP_PROXY="http://proxy.alcf.anl.gov:3128"
export HTTPS_PROXY="http://proxy.alcf.anl.gov:3128"
export http_proxy="http://proxy.alcf.anl.gov:3128"
export https_proxy="http://proxy.alcf.anl.gov:3128"
export ftp_proxy="http://proxy.alcf.anl.gov:3128"
export no_proxy="admin,polaris-adminvm-01,localhost,*.cm.polaris.alcf.anl.gov,polaris-*,*.polaris.alcf.anl.gov,*.alcf.anl.gov"

export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

cd ${PROJECT_DIR}

echo "=============================================="
echo "Evaluation — ${MODEL_PATH}"
echo "Node: $(hostname)"
echo "Date: $(date)"
echo "=============================================="

nvidia-smi

# Run generate + evaluate for MolOpt (LogP, MR, QED)
# Generate predictions (English prompts)
for SUBTASK in LogP MR QED; do
    echo "[generate] MolOpt-${SUBTASK} | model=${MODEL_PATH}"
    CUDA_VISIBLE_DEVICES=0 python generate_predictions.py \
        --model_path "${MODEL_PATH}" \
        --benchmark open_generation \
        --task MolOpt \
        --subtask "${SUBTASK}" \
        --output_dir ./predictions/ \
        --gpu_memory_utilization 0.90 \
        --lang en

    echo "[evaluate] MolOpt-${SUBTASK} | model=${MODEL_PATH}"
    CUDA_VISIBLE_DEVICES=0 python evaluate.py \
        --model_path "${MODEL_PATH}" \
        --benchmark open_generation \
        --task MolOpt \
        --subtask "${SUBTASK}" \
        --output_dir ./predictions/
done

echo "=============================================="
echo "Evaluation complete at $(date)"
echo "=============================================="
